+//===--------------------------------------------------------------------===//
+// Helpers
+//===--------------------------------------------------------------------===//
+
+//! Build the high32 -> Roaring map from a vector of 64-bit positions.
+static unordered_map<int32_t, roaring::Roaring> BuildBitmaps(const vector<int64_t> &positions) {
+	unordered_map<int32_t, roaring::Roaring> bitmaps;
+	for (auto pos : positions) {
+		if (pos < 0) {
+			throw InvalidInputException("iceberg deletion vector: positions must be non-negative, got %lld", pos);
+		}
+		int32_t high = static_cast<int32_t>(static_cast<uint64_t>(pos) >> 32);
+		uint32_t low = static_cast<uint32_t>(static_cast<uint64_t>(pos) & 0xFFFFFFFFu);
+		bitmaps[high].add(low);
+	}
+	return bitmaps;
+}
+
+//! Drain a bitmap map into a sorted vector of full 64-bit positions.
+static vector<int64_t> MaterializeSortedPositions(const unordered_map<int32_t, roaring::Roaring> &bitmaps) {
+	vector<int64_t> out;
+	uint64_t total = 0;
+	for (auto &kv : bitmaps) {
+		total += kv.second.cardinality();
+	}
+	out.reserve(total);
+	struct IterCtx {
+		vector<int64_t> *out;
+		int32_t high;
+	};
+	for (auto &kv : bitmaps) {
+		IterCtx ctx {&out, kv.first};
+		kv.second.iterate(
+		    [](uint32_t value, void *ptr) -> bool {
+			    auto *c = static_cast<IterCtx *>(ptr);
+			    uint64_t combined =
+			        (static_cast<uint64_t>(static_cast<uint32_t>(c->high)) << 32) | static_cast<uint64_t>(value);
+			    c->out->push_back(static_cast<int64_t>(combined));
+			    return true;
+		    },
+		    &ctx);
+	}
+	std::sort(out.begin(), out.end());
+	return out;
+}
+
+//! Extract a flat vector of int64 positions from a LIST(BIGINT) Value.
+static vector<int64_t> ListValueToInt64Vector(const Value &list_val) {
+	if (list_val.IsNull()) {
+		return {};
+	}
+	auto &children = ListValue::GetChildren(list_val);
+	vector<int64_t> out;
+	out.reserve(children.size());
+	for (auto &child : children) {
+		if (child.IsNull()) {
+			continue;
+		}
+		out.push_back(child.GetValue<int64_t>());
+	}
+	return out;
+}
+
+//===--------------------------------------------------------------------===//
+// Scalar: iceberg_dv_encode(BIGINT[]) -> BLOB
+//===--------------------------------------------------------------------===//
+
+static void IcebergDvEncodeFunction(DataChunk &input, ExpressionState &state, Vector &result) {
+	auto count = input.size();
+	auto &list_vec = input.data[0];
+	UnifiedVectorFormat list_format;
+	list_vec.ToUnifiedFormat(count, list_format);
+	auto list_entries = UnifiedVectorFormat::GetData<list_entry_t>(list_format);
+
+	auto &child_vec = ListVector::GetEntry(list_vec);
+	auto child_size = ListVector::GetListSize(list_vec);
+	UnifiedVectorFormat child_format;
+	child_vec.ToUnifiedFormat(child_size, child_format);
+	auto child_data = UnifiedVectorFormat::GetData<int64_t>(child_format);
+
+	auto result_data = FlatVector::GetData<string_t>(result);
+	auto &result_validity = FlatVector::Validity(result);
+
+	for (idx_t i = 0; i < count; i++) {
+		auto list_idx = list_format.sel->get_index(i);
+		if (!list_format.validity.RowIsValid(list_idx)) {
+			result_validity.SetInvalid(i);
+			continue;
+		}
+		auto entry = list_entries[list_idx];
+
+		vector<int64_t> positions;
+		positions.reserve(entry.length);
+		for (idx_t j = 0; j < entry.length; j++) {
+			auto child_idx = child_format.sel->get_index(entry.offset + j);
+			if (!child_format.validity.RowIsValid(child_idx)) {
+				continue;
+			}
+			positions.push_back(child_data[child_idx]);
+		}
+
+		auto bitmaps = BuildBitmaps(positions);
+		auto blob_bytes = IcebergDeletionVectorData::ToBlob(bitmaps);
+		result_data[i] =
+		    StringVector::AddStringOrBlob(result, string_t((const char *)blob_bytes.data(), blob_bytes.size()));
+	}
+	if (count == 1) {
+		result.SetVectorType(VectorType::CONSTANT_VECTOR);
+	}
+}
+
+} // namespace
+
+ScalarFunctionSet IcebergPuffinDvFunctions::GetEncodeFunction() {
+	ScalarFunctionSet set("iceberg_dv_encode");
+	set.AddFunction(ScalarFunction({LogicalType::LIST(LogicalType::BIGINT)}, LogicalType::BLOB,
+	                               IcebergDvEncodeFunction));
+	return set;
+}
