+//===--------------------------------------------------------------------===//
+// TVF: iceberg_dv_decode(blob) -> (pos BIGINT)
+//===--------------------------------------------------------------------===//
+
+namespace {
+
+struct DvDecodeBindData : public TableFunctionData {
+	vector<int64_t> positions;
+};
+
+struct DvDecodeGlobalState : public GlobalTableFunctionState {
+	idx_t emit_offset = 0;
+};
+
+static unique_ptr<FunctionData> DvDecodeBind(ClientContext &context, TableFunctionBindInput &input,
+                                             vector<LogicalType> &return_types, vector<string> &names) {
+	auto result = make_uniq<DvDecodeBindData>();
+	auto blob_str = input.inputs[0].GetValueUnsafe<string_t>();
+
+	unordered_map<int32_t, roaring::Roaring> bitmaps;
+	IcebergDeletionVectorData::ParseBlob((data_ptr_t)blob_str.GetData(), blob_str.GetSize(), bitmaps);
+	result->positions = MaterializeSortedPositions(bitmaps);
+
+	return_types = {LogicalType::BIGINT};
+	names = {"pos"};
+	return std::move(result);
+}
+
+static unique_ptr<GlobalTableFunctionState> DvDecodeInit(ClientContext &context, TableFunctionInitInput &input) {
+	return make_uniq<DvDecodeGlobalState>();
+}
+
+static void DvDecodeFunction(ClientContext &context, TableFunctionInput &input, DataChunk &output) {
+	auto &bind_data = input.bind_data->Cast<DvDecodeBindData>();
+	auto &state = input.global_state->Cast<DvDecodeGlobalState>();
+	idx_t remaining = bind_data.positions.size() - state.emit_offset;
+	idx_t emit = MinValue<idx_t>(remaining, STANDARD_VECTOR_SIZE);
+	output.SetCardinality(emit);
+	auto data = FlatVector::GetData<int64_t>(output.data[0]);
+	for (idx_t i = 0; i < emit; i++) {
+		data[i] = bind_data.positions[state.emit_offset + i];
+	}
+	state.emit_offset += emit;
+}
+
+} // namespace
+
+TableFunctionSet IcebergPuffinDvFunctions::GetDecodeFunction() {
+	TableFunctionSet set("iceberg_dv_decode");
+	set.AddFunction(TableFunction({LogicalType::BLOB}, DvDecodeFunction, DvDecodeBind, DvDecodeInit));
+	return set;
+}
