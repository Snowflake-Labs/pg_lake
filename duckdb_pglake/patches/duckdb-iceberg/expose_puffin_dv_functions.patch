@@ -0,0 +1,359 @@
+//===----------------------------------------------------------------------===//
+//                         duckdb-iceberg
+//
+// iceberg_puffin.cpp
+//
+// Implementation notes:
+//
+//   File layout (Iceberg Puffin spec, all multi-byte ints are little-endian
+//   unless noted):
+//
+//     +-----------------------------+ offset 0
+//     | head magic "PFA1" (4 bytes) |
+//     +-----------------------------+
+//     | blob[0] payload bytes       |
+//     | ...                         |
+//     | blob[N-1] payload bytes     |
+//     +-----------------------------+
+//     | footer start magic "PFA1"   |
+//     | footer payload JSON         |  <-- footer_payload_length bytes,
+//     |                             |      may be LZ4-compressed (flag bit 0)
+//     | footer_payload_length (i32) |
+//     | flags                 (i32) |
+//     | tail magic "PFA1"           |
+//     +-----------------------------+ EOF
+//
+// We always write Flags=0 (uncompressed footer). The reader rejects
+// Flags != 0 with a clear error instead of silently producing garbage.
+//
+//===----------------------------------------------------------------------===//
+
+#include "common/iceberg_puffin.hpp"
+
+#include "duckdb/common/exception.hpp"
+#include "duckdb/common/file_system.hpp"
+#include "duckdb/common/types/uuid.hpp"
+#include "yyjson.hpp"
+
+using namespace duckdb_yyjson;
+
+namespace duckdb {
+
+const char ICEBERG_PUFFIN_MAGIC[4] = {'P', 'F', 'A', '1'};
+
+namespace {
+
+constexpr idx_t PUFFIN_MAGIC_SIZE = 4;
+//! footer_payload_length(4) + flags(4) + tail magic(4) = 12 bytes
+constexpr idx_t PUFFIN_FOOTER_TRAILER_SIZE = sizeof(int32_t) + sizeof(int32_t) + PUFFIN_MAGIC_SIZE;
+
+static int32_t LoadLittleEndian32(const data_t *src) {
+	int32_t v = 0;
+	memcpy(&v, src, sizeof(int32_t));
+	return v;
+}
+
+static void StoreLittleEndian32(int32_t v, data_t *dst) {
+	memcpy(dst, &v, sizeof(int32_t));
+}
+
+static yyjson_mut_val *BuildFieldsArray(yyjson_mut_doc *doc, const vector<int32_t> &fields) {
+	auto arr = yyjson_mut_arr(doc);
+	for (auto field : fields) {
+		yyjson_mut_arr_add_int(doc, arr, field);
+	}
+	return arr;
+}
+
+static yyjson_mut_val *BuildPropertiesObject(yyjson_mut_doc *doc, const map<string, string> &props) {
+	auto obj = yyjson_mut_obj(doc);
+	for (auto &kv : props) {
+		yyjson_mut_obj_add_strcpy(doc, obj, kv.first.c_str(), kv.second.c_str());
+	}
+	return obj;
+}
+
+static string BuildFooterJSON(const vector<IcebergPuffinBlob> &blobs, const map<string, string> &file_properties) {
+	auto doc = yyjson_mut_doc_new(nullptr);
+	if (!doc) {
+		throw IOException("Failed to allocate yyjson document for Puffin footer");
+	}
+	auto root = yyjson_mut_obj(doc);
+	yyjson_mut_doc_set_root(doc, root);
+
+	auto blobs_arr = yyjson_mut_arr(doc);
+	yyjson_mut_obj_add_val(doc, root, "blobs", blobs_arr);
+	for (auto &b : blobs) {
+		auto bobj = yyjson_mut_obj(doc);
+		//! Field order mirrors apache/iceberg's FileMetadataParser.toJson so a
+		//! byte-equal hash against Spark's writer output is achievable for the
+		//! same input. Required fields per the Puffin spec are: type, fields,
+		//! snapshot-id, sequence-number, offset, length. snapshot-id and
+		//! sequence-number MUST be present for any Puffin v1 file - for
+		//! deletion-vector-v1 blobs the spec mandates -1 (which is exactly the
+		//! default value of IcebergPuffinBlob::{snapshot_id,sequence_number}).
+		yyjson_mut_obj_add_strcpy(doc, bobj, "type", b.type.c_str());
+		yyjson_mut_obj_add_val(doc, bobj, "fields", BuildFieldsArray(doc, b.fields));
+		yyjson_mut_obj_add_int(doc, bobj, "snapshot-id", b.snapshot_id);
+		yyjson_mut_obj_add_int(doc, bobj, "sequence-number", b.sequence_number);
+		yyjson_mut_obj_add_int(doc, bobj, "offset", b.offset);
+		yyjson_mut_obj_add_int(doc, bobj, "length", b.length);
+		if (!b.compression_codec.empty()) {
+			yyjson_mut_obj_add_strcpy(doc, bobj, "compression-codec", b.compression_codec.c_str());
+		}
+		if (!b.properties.empty()) {
+			yyjson_mut_obj_add_val(doc, bobj, "properties", BuildPropertiesObject(doc, b.properties));
+		}
+		yyjson_mut_arr_add_val(blobs_arr, bobj);
+	}
+	if (!file_properties.empty()) {
+		yyjson_mut_obj_add_val(doc, root, "properties", BuildPropertiesObject(doc, file_properties));
+	}
+
+	size_t json_len = 0;
+	char *json_str = yyjson_mut_write(doc, 0, &json_len);
+	if (!json_str) {
+		yyjson_mut_doc_free(doc);
+		throw IOException("Failed to serialize Puffin footer JSON");
+	}
+	string out(json_str, json_len);
+	free(json_str);
+	yyjson_mut_doc_free(doc);
+	return out;
+}
+
+static IcebergPuffinBlob ParseBlobObject(yyjson_val *obj) {
+	IcebergPuffinBlob blob;
+	auto type_val = yyjson_obj_get(obj, "type");
+	if (!type_val || !yyjson_is_str(type_val)) {
+		throw InvalidInputException("Puffin footer blob is missing required string field 'type'");
+	}
+	blob.type = yyjson_get_str(type_val);
+
+	auto offset_val = yyjson_obj_get(obj, "offset");
+	auto length_val = yyjson_obj_get(obj, "length");
+	if (!offset_val || !yyjson_is_int(offset_val) || !length_val || !yyjson_is_int(length_val)) {
+		throw InvalidInputException("Puffin footer blob is missing required integer 'offset'/'length'");
+	}
+	blob.offset = yyjson_get_sint(offset_val);
+	blob.length = yyjson_get_sint(length_val);
+
+	if (auto fields_val = yyjson_obj_get(obj, "fields")) {
+		if (!yyjson_is_arr(fields_val)) {
+			throw InvalidInputException("Puffin footer blob 'fields' must be an array");
+		}
+		size_t idx, max;
+		yyjson_val *item;
+		yyjson_arr_foreach(fields_val, idx, max, item) {
+			blob.fields.push_back(static_cast<int32_t>(yyjson_get_sint(item)));
+		}
+	}
+	if (auto snap_val = yyjson_obj_get(obj, "snapshot-id")) {
+		if (yyjson_is_int(snap_val)) {
+			blob.snapshot_id = yyjson_get_sint(snap_val);
+		}
+	}
+	if (auto seq_val = yyjson_obj_get(obj, "sequence-number")) {
+		if (yyjson_is_int(seq_val)) {
+			blob.sequence_number = yyjson_get_sint(seq_val);
+		}
+	}
+	if (auto codec_val = yyjson_obj_get(obj, "compression-codec")) {
+		if (yyjson_is_str(codec_val)) {
+			blob.compression_codec = yyjson_get_str(codec_val);
+		}
+	}
+	if (auto props_val = yyjson_obj_get(obj, "properties")) {
+		if (!yyjson_is_obj(props_val)) {
+			throw InvalidInputException("Puffin footer blob 'properties' must be an object");
+		}
+		size_t idx, max;
+		yyjson_val *key, *val;
+		yyjson_obj_foreach(props_val, idx, max, key, val) {
+			if (yyjson_is_str(key) && yyjson_is_str(val)) {
+				blob.properties[yyjson_get_str(key)] = yyjson_get_str(val);
+			}
+		}
+	}
+	return blob;
+}
+
+static IcebergPuffinMetadata ParseFooterJSON(const char *json, size_t json_len, int64_t file_size,
+                                             bool footer_compressed) {
+	yyjson_doc *doc = yyjson_read(json, json_len, 0);
+	if (!doc) {
+		throw InvalidInputException("Puffin footer JSON is not valid: parse error");
+	}
+	yyjson_val *root = yyjson_doc_get_root(doc);
+	if (!root || !yyjson_is_obj(root)) {
+		yyjson_doc_free(doc);
+		throw InvalidInputException("Puffin footer JSON root must be a JSON object");
+	}
+
+	IcebergPuffinMetadata result;
+	result.file_size = file_size;
+	result.footer_compressed = footer_compressed;
+
+	auto blobs_val = yyjson_obj_get(root, "blobs");
+	if (!blobs_val || !yyjson_is_arr(blobs_val)) {
+		yyjson_doc_free(doc);
+		throw InvalidInputException("Puffin footer is missing the required 'blobs' array");
+	}
+	size_t idx, max;
+	yyjson_val *item;
+	yyjson_arr_foreach(blobs_val, idx, max, item) {
+		result.blobs.push_back(ParseBlobObject(item));
+	}
+	if (auto props_val = yyjson_obj_get(root, "properties")) {
+		if (yyjson_is_obj(props_val)) {
+			size_t pi, pmax;
+			yyjson_val *pkey, *pval;
+			yyjson_obj_foreach(props_val, pi, pmax, pkey, pval) {
+				if (yyjson_is_str(pkey) && yyjson_is_str(pval)) {
+					result.properties[yyjson_get_str(pkey)] = yyjson_get_str(pval);
+				}
+			}
+		}
+	}
+	yyjson_doc_free(doc);
+	return result;
+}
+
+} // namespace
+
+//===--------------------------------------------------------------------===//
+// IcebergPuffinFile::ReadMetadata
+//===--------------------------------------------------------------------===//
+IcebergPuffinMetadata IcebergPuffinFile::ReadMetadata(FileSystem &fs, const string &path) {
+	auto handle = fs.OpenFile(path, FileOpenFlags::FILE_FLAGS_READ);
+	int64_t file_size = handle->GetFileSize();
+	if (file_size < (int64_t)(PUFFIN_MAGIC_SIZE + PUFFIN_FOOTER_TRAILER_SIZE + PUFFIN_MAGIC_SIZE)) {
+		throw InvalidInputException("File '%s' is too small (%lld bytes) to be a valid Puffin file", path, file_size);
+	}
+
+	//! Verify head magic.
+	data_t head[PUFFIN_MAGIC_SIZE];
+	handle->Read(head, PUFFIN_MAGIC_SIZE, 0);
+	if (memcmp(head, ICEBERG_PUFFIN_MAGIC, PUFFIN_MAGIC_SIZE) != 0) {
+		throw InvalidInputException("File '%s' is not a Puffin file: head magic mismatch (expected 'PFA1')", path);
+	}
+
+	//! Read the trailer: footer_payload_length (4 LE) + flags (4 LE) + tail magic (4).
+	data_t trailer[PUFFIN_FOOTER_TRAILER_SIZE];
+	handle->Read(trailer, PUFFIN_FOOTER_TRAILER_SIZE, file_size - (int64_t)PUFFIN_FOOTER_TRAILER_SIZE);
+	if (memcmp(trailer + sizeof(int32_t) * 2, ICEBERG_PUFFIN_MAGIC, PUFFIN_MAGIC_SIZE) != 0) {
+		throw InvalidInputException("File '%s' is not a Puffin file: tail magic mismatch (expected 'PFA1')", path);
+	}
+	int32_t footer_payload_length = LoadLittleEndian32(trailer);
+	int32_t flags = LoadLittleEndian32(trailer + sizeof(int32_t));
+	bool footer_compressed = (flags & 0x1) != 0;
+	if (flags & ~0x1) {
+		throw InvalidInputException("File '%s' has unknown Puffin footer flags (0x%x)", path, flags);
+	}
+	if (footer_compressed) {
+		throw NotImplementedException(
+		    "File '%s' has an LZ4-compressed Puffin footer; this reader currently supports uncompressed footers only",
+		    path);
+	}
+	if (footer_payload_length < 0) {
+		throw InvalidInputException("File '%s' has a negative Puffin footer payload length (%d)", path,
+		                            footer_payload_length);
+	}
+
+	//! Footer payload sits immediately before the trailer, prefixed by the footer-start magic.
+	int64_t footer_start = file_size - (int64_t)PUFFIN_FOOTER_TRAILER_SIZE - (int64_t)footer_payload_length -
+	                       (int64_t)PUFFIN_MAGIC_SIZE;
+	if (footer_start < (int64_t)PUFFIN_MAGIC_SIZE) {
+		throw InvalidInputException("File '%s' Puffin footer offsets are inconsistent (footer_start=%lld)", path,
+		                            footer_start);
+	}
+	data_t footer_magic[PUFFIN_MAGIC_SIZE];
+	handle->Read(footer_magic, PUFFIN_MAGIC_SIZE, footer_start);
+	if (memcmp(footer_magic, ICEBERG_PUFFIN_MAGIC, PUFFIN_MAGIC_SIZE) != 0) {
+		throw InvalidInputException("File '%s' Puffin footer-start magic mismatch", path);
+	}
+	vector<char> footer_payload(footer_payload_length);
+	if (footer_payload_length > 0) {
+		handle->Read((data_ptr_t)footer_payload.data(), footer_payload_length,
+		             footer_start + (int64_t)PUFFIN_MAGIC_SIZE);
+	}
+	return ParseFooterJSON(footer_payload.data(), footer_payload_length, file_size, footer_compressed);
+}
+
+//===--------------------------------------------------------------------===//
+// IcebergPuffinFile::ReadBlobPayload
+//===--------------------------------------------------------------------===//
+vector<data_t> IcebergPuffinFile::ReadBlobPayload(FileSystem &fs, const string &path, int64_t offset, int64_t length) {
+	if (offset < 0 || length < 0) {
+		throw InvalidInputException("iceberg_puffin: negative blob offset (%lld) or length (%lld)", offset, length);
+	}
+	auto handle = fs.OpenFile(path, FileOpenFlags::FILE_FLAGS_READ);
+	vector<data_t> out(length);
+	if (length > 0) {
+		handle->Read(out.data(), length, offset);
+	}
+	return out;
+}
+
+//===--------------------------------------------------------------------===//
+// IcebergPuffinFile::Write
+//===--------------------------------------------------------------------===//
+IcebergPuffinMetadata IcebergPuffinFile::Write(FileSystem &fs, const string &path, vector<IcebergPuffinBlob> blobs,
+                                               const map<string, string> &file_properties) {
+	if (blobs.empty()) {
+		throw InvalidInputException("iceberg_puffin_write: at least one blob is required");
+	}
+
+	auto handle = fs.OpenFile(path, FileOpenFlags::FILE_FLAGS_WRITE | FileOpenFlags::FILE_FLAGS_FILE_CREATE);
+
+	//! Head magic.
+	handle->Write((void *)ICEBERG_PUFFIN_MAGIC, PUFFIN_MAGIC_SIZE);
+	int64_t cursor = (int64_t)PUFFIN_MAGIC_SIZE;
+
+	//! Write blob payloads, capturing their absolute offsets and lengths.
+	for (auto &blob : blobs) {
+		blob.offset = cursor;
+		blob.length = static_cast<int64_t>(blob.payload.size());
+		if (blob.length > 0) {
+			handle->Write(blob.payload.data(), blob.length);
+		}
+		cursor += blob.length;
+	}
+
+	//! Footer start magic.
+	handle->Write((void *)ICEBERG_PUFFIN_MAGIC, PUFFIN_MAGIC_SIZE);
+	cursor += (int64_t)PUFFIN_MAGIC_SIZE;
+
+	//! Footer payload JSON.
+	string footer_json = BuildFooterJSON(blobs, file_properties);
+	if (footer_json.size() > (size_t)INT32_MAX) {
+		throw IOException("Puffin footer payload exceeds 2 GiB");
+	}
+	if (!footer_json.empty()) {
+		handle->Write((void *)footer_json.data(), footer_json.size());
+	}
+	cursor += (int64_t)footer_json.size();
+
+	//! footer_payload_length, flags (uncompressed), tail magic.
+	data_t trailer[PUFFIN_FOOTER_TRAILER_SIZE];
+	StoreLittleEndian32(static_cast<int32_t>(footer_json.size()), trailer);
+	StoreLittleEndian32(0, trailer + sizeof(int32_t));
+	memcpy(trailer + sizeof(int32_t) * 2, ICEBERG_PUFFIN_MAGIC, PUFFIN_MAGIC_SIZE);
+	handle->Write(trailer, PUFFIN_FOOTER_TRAILER_SIZE);
+	cursor += (int64_t)PUFFIN_FOOTER_TRAILER_SIZE;
+
+	handle->Close();
+
+	IcebergPuffinMetadata meta;
+	meta.file_size = cursor;
+	meta.properties = file_properties;
+	meta.blobs = std::move(blobs);
+	//! Caller does not need the payload anymore; drop it to keep the result light.
+	for (auto &b : meta.blobs) {
+		b.payload.clear();
+		b.payload.shrink_to_fit();
+	}
+	return meta;
+}
+
+} // namespace duckdb
