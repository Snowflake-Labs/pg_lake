+//===--------------------------------------------------------------------===//
+// TVF: iceberg_puffin_write(path, blob_types VARCHAR[], blob_payloads BLOB[])
+//===--------------------------------------------------------------------===//
+
+namespace {
+
+struct PuffinWriteBindData : public TableFunctionData {
+	IcebergPuffinMetadata result_metadata;
+};
+
+struct PuffinWriteGlobalState : public GlobalTableFunctionState {
+	idx_t emit_offset = 0;
+};
+
+static unique_ptr<FunctionData> PuffinWriteBind(ClientContext &context, TableFunctionBindInput &input,
+                                                vector<LogicalType> &return_types, vector<string> &names) {
+	auto result = make_uniq<PuffinWriteBindData>();
+	auto path = input.inputs[0].GetValue<string>();
+
+	auto &types_val = input.inputs[1];
+	auto &payloads_val = input.inputs[2];
+	auto &types_children = ListValue::GetChildren(types_val);
+	auto &payloads_children = ListValue::GetChildren(payloads_val);
+	if (types_children.size() != payloads_children.size()) {
+		throw InvalidInputException(
+		    "iceberg_puffin_write: blob_types and blob_payloads must have the same length (got %lld vs %lld)",
+		    (int64_t)types_children.size(), (int64_t)payloads_children.size());
+	}
+	if (types_children.empty()) {
+		throw InvalidInputException("iceberg_puffin_write: at least one blob is required");
+	}
+
+	vector<IcebergPuffinBlob> blobs;
+	blobs.reserve(types_children.size());
+	for (idx_t i = 0; i < types_children.size(); i++) {
+		IcebergPuffinBlob b;
+		b.type = types_children[i].GetValue<string>();
+		auto &payload_val = payloads_children[i];
+		auto payload_str = payload_val.GetValueUnsafe<string_t>();
+		b.payload.assign((const data_t *)payload_str.GetData(),
+		                 (const data_t *)payload_str.GetData() + payload_str.GetSize());
+		blobs.push_back(std::move(b));
+	}
+	auto &fs = FileSystem::GetFileSystem(context);
+	result->result_metadata = IcebergPuffinFile::Write(fs, path, std::move(blobs));
+
+	return_types = {LogicalType::INTEGER, LogicalType::VARCHAR, LogicalType::BIGINT, LogicalType::BIGINT,
+	                LogicalType::BIGINT};
+	names = {"blob_idx", "blob_type", "blob_offset", "blob_length", "file_size"};
+	return std::move(result);
+}
+
+static unique_ptr<GlobalTableFunctionState> PuffinWriteInit(ClientContext &context, TableFunctionInitInput &input) {
+	return make_uniq<PuffinWriteGlobalState>();
+}
+
+static void PuffinWriteFunction(ClientContext &context, TableFunctionInput &input, DataChunk &output) {
+	auto &bind_data = input.bind_data->Cast<PuffinWriteBindData>();
+	auto &state = input.global_state->Cast<PuffinWriteGlobalState>();
+	auto &md = bind_data.result_metadata;
+	idx_t remaining = md.blobs.size() - state.emit_offset;
+	idx_t emit = MinValue<idx_t>(remaining, STANDARD_VECTOR_SIZE);
+	output.SetCardinality(emit);
+	for (idx_t i = 0; i < emit; i++) {
+		auto idx = state.emit_offset + i;
+		auto &b = md.blobs[idx];
+		output.SetValue(0, i, Value::INTEGER(static_cast<int32_t>(idx)));
+		output.SetValue(1, i, Value(b.type));
+		output.SetValue(2, i, Value::BIGINT(b.offset));
+		output.SetValue(3, i, Value::BIGINT(b.length));
+		output.SetValue(4, i, Value::BIGINT(md.file_size));
+	}
+	state.emit_offset += emit;
+}
+
+} // namespace
+
+TableFunctionSet IcebergPuffinDvFunctions::GetWriteFunction() {
+	TableFunctionSet set("iceberg_puffin_write");
+	set.AddFunction(TableFunction({LogicalType::VARCHAR, LogicalType::LIST(LogicalType::VARCHAR),
+	                               LogicalType::LIST(LogicalType::BLOB)},
+	                              PuffinWriteFunction, PuffinWriteBind, PuffinWriteInit));
+	return set;
+}
