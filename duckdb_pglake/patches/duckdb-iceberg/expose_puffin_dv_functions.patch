+//===--------------------------------------------------------------------===//
+// TVF: iceberg_dv_positions(paths VARCHAR[], offsets BIGINT[],
+//                           sizes BIGINT[], referenced_data_files VARCHAR[])
+//      -> TABLE(file_path VARCHAR, pos BIGINT)
+//
+// Multi-blob deletion-vector reader. For every i in [0, len(paths)) it
+// reads the deletion-vector-v1 blob at [offsets[i], offsets[i]+sizes[i])
+// inside the Puffin file at paths[i], decodes it, and emits one row per
+// deleted position with `file_path = referenced_data_files[i]`.
+//
+// The shape mirrors `read_parquet(<positional-delete-files>)`: one TVF
+// call covers a whole scan's worth of DVs, so a query that touches N
+// data files no longer needs an N-leg UNION ALL. The caller (in
+// pg_lake_engine/src/pgduck/read_data.c) builds the four parallel
+// arrays directly from its in-memory `DataFile[]`:
+//
+//   SELECT file_path, pos
+//   FROM iceberg_dv_positions(
+//       ['<p_1>',   '<p_2>',   ...],   -- puffin file paths
+//       [<offset_1>, <offset_2>, ...], -- manifest entry's content_offset (144)
+//       [<size_1>,   <size_2>,   ...], -- manifest entry's content_size_in_bytes (145)
+//       ['<ref_1>', '<ref_2>', ...]    -- manifest entry's referenced_data_file (143)
+//   );
+//
+// `referenced_data_files[i]` is purely the per-blob label stamped onto
+// each output row (the Puffin DV blob itself does not carry a required
+// pointer to its data file - the spec stores that in the manifest
+// entry, and the TVF receives it from the manifest reader).
+//
+// If multiple manifest entries share the same Puffin file (multi-blob
+// Puffin pattern), simply pass the same path multiple times with
+// different (offset, size, ref) triples; each blob is read independently.
+//===--------------------------------------------------------------------===//
+
+namespace {
+
+struct DvPositionsBindData : public TableFunctionData {
+	//! Parallel vectors: positions[i] is a deleted row position whose source
+	//! data file is file_paths[i]. We materialise a flat (file_path, pos)
+	//! tuple stream at bind time so the function can emit STANDARD_VECTOR_SIZE
+	//! chunks without touching the file system.
+	vector<string> file_paths;
+	vector<int64_t> positions;
+};
+
+static unique_ptr<FunctionData> DvPositionsBind(ClientContext &context, TableFunctionBindInput &input,
+                                                vector<LogicalType> &return_types, vector<string> &names) {
+	auto result = make_uniq<DvPositionsBindData>();
+
+	auto &paths_children = ListValue::GetChildren(input.inputs[0]);
+	auto &offsets_children = ListValue::GetChildren(input.inputs[1]);
+	auto &sizes_children = ListValue::GetChildren(input.inputs[2]);
+	auto &refs_children = ListValue::GetChildren(input.inputs[3]);
+	idx_t n = paths_children.size();
+	if (offsets_children.size() != n || sizes_children.size() != n || refs_children.size() != n) {
+		throw InvalidInputException(
+		    "iceberg_dv_positions: the four input arrays must have equal length, "
+		    "got paths=%lld, offsets=%lld, sizes=%lld, referenced_data_files=%lld",
+		    (int64_t)n, (int64_t)offsets_children.size(), (int64_t)sizes_children.size(),
+		    (int64_t)refs_children.size());
+	}
+
+	auto &fs = FileSystem::GetFileSystem(context);
+	for (idx_t i = 0; i < n; i++) {
+		if (paths_children[i].IsNull() || offsets_children[i].IsNull() || sizes_children[i].IsNull() ||
+		    refs_children[i].IsNull()) {
+			throw InvalidInputException("iceberg_dv_positions: NULL element at index %lld", (int64_t)i);
+		}
+		auto path = paths_children[i].GetValue<string>();
+		auto offset = offsets_children[i].GetValue<int64_t>();
+		auto length = sizes_children[i].GetValue<int64_t>();
+		auto ref = refs_children[i].GetValue<string>();
+
+		auto payload = IcebergPuffinFile::ReadBlobPayload(fs, path, offset, length);
+		unordered_map<int32_t, roaring::Roaring> bitmaps;
+		IcebergDeletionVectorData::ParseBlob(payload.data(), payload.size(), bitmaps);
+		auto positions = MaterializeSortedPositions(bitmaps);
+		result->file_paths.insert(result->file_paths.end(), positions.size(), ref);
+		result->positions.insert(result->positions.end(), positions.begin(), positions.end());
+	}
+
+	return_types = {LogicalType::VARCHAR, LogicalType::BIGINT};
+	names = {"file_path", "pos"};
+	return std::move(result);
+}
+
+static void DvPositionsFunction(ClientContext &context, TableFunctionInput &input, DataChunk &output) {
+	auto &bind_data = input.bind_data->Cast<DvPositionsBindData>();
+	auto &state = input.global_state->Cast<DvDecodeGlobalState>();
+	idx_t remaining = bind_data.positions.size() - state.emit_offset;
+	idx_t emit = MinValue<idx_t>(remaining, STANDARD_VECTOR_SIZE);
+	output.SetCardinality(emit);
+	auto pos_data = FlatVector::GetData<int64_t>(output.data[1]);
+	for (idx_t i = 0; i < emit; i++) {
+		auto idx = state.emit_offset + i;
+		output.SetValue(0, i, Value(bind_data.file_paths[idx]));
+		pos_data[i] = bind_data.positions[idx];
+	}
+	state.emit_offset += emit;
+}
+
+} // namespace
+
+TableFunctionSet IcebergPuffinDvFunctions::GetDvPositionsFunction() {
+	TableFunctionSet set("iceberg_dv_positions");
+	set.AddFunction(TableFunction({LogicalType::LIST(LogicalType::VARCHAR), LogicalType::LIST(LogicalType::BIGINT),
+	                               LogicalType::LIST(LogicalType::BIGINT), LogicalType::LIST(LogicalType::VARCHAR)},
+	                              DvPositionsFunction, DvPositionsBind, DvDecodeInit));
+	return set;
+}
+
+//===--------------------------------------------------------------------===//
+// TVF: iceberg_write_dvs(path, referenced_data_file, positions BIGINT[])
+//
+// Writes a single-blob Puffin file containing one deletion-vector-v1 blob
+// for the given referenced_data_file. Returns one row with the manifest
+// fields the future pg_lake_iceberg V3 writer will persist.
+//===--------------------------------------------------------------------===//
+
+namespace {
+
+struct WriteDvsBindData : public TableFunctionData {
+	string referenced_data_file;
+	int64_t content_offset = 0;
+	int64_t content_size_in_bytes = 0;
+	int64_t cardinality = 0;
+	int64_t file_size = 0;
+};
+
+struct WriteDvsGlobalState : public GlobalTableFunctionState {
+	bool emitted = false;
+};
+
+static unique_ptr<FunctionData> WriteDvsBind(ClientContext &context, TableFunctionBindInput &input,
+                                             vector<LogicalType> &return_types, vector<string> &names) {
+	auto result = make_uniq<WriteDvsBindData>();
+	auto path = input.inputs[0].GetValue<string>();
+	result->referenced_data_file = input.inputs[1].GetValue<string>();
+	auto positions = ListValueToInt64Vector(input.inputs[2]);
+	result->cardinality = static_cast<int64_t>(positions.size());
+
+	auto bitmaps = BuildBitmaps(positions);
+	auto blob_bytes = IcebergDeletionVectorData::ToBlob(bitmaps);
+
+	IcebergPuffinBlob blob;
+	blob.type = "deletion-vector-v1";
+	//! Puffin spec requires `fields = [<row-position field id>]` for
+	//! `deletion-vector-v1` blobs. The row-position field id is the Iceberg
+	//! reserved id for `_pos` in any data file's schema (apache/iceberg's
+	//! MetadataColumns.ROW_POSITION). Spark/Iceberg-Java write this; without
+	//! it, conformant readers reject the blob.
+	constexpr int32_t ICEBERG_ROW_POSITION_FIELD_ID = 2147483546;
+	blob.fields = {ICEBERG_ROW_POSITION_FIELD_ID};
+	//! Spec-required: `cardinality` reports the number of deleted positions
+	//! encoded by this DV. Optional but Spark-emitted: `referenced-data-file`
+	//! mirrors the manifest entry's field 143 inside the blob itself. The
+	//! reader resolves the data file via the manifest (entry's
+	//! `referenced_data_file`), so the blob property is purely informational.
+	blob.properties["cardinality"] = StringUtil::Format("%lld", result->cardinality);
+	blob.properties["referenced-data-file"] = result->referenced_data_file;
+	blob.payload.assign(blob_bytes.begin(), blob_bytes.end());
+
+	vector<IcebergPuffinBlob> blobs;
+	blobs.push_back(std::move(blob));
+	auto &fs = FileSystem::GetFileSystem(context);
+	auto written = IcebergPuffinFile::Write(fs, path, std::move(blobs));
+	result->content_offset = written.blobs[0].offset;
+	result->content_size_in_bytes = written.blobs[0].length;
+	result->file_size = written.file_size;
+
+	return_types = {LogicalType::VARCHAR, LogicalType::BIGINT, LogicalType::BIGINT, LogicalType::BIGINT,
+	                LogicalType::BIGINT};
+	names = {"referenced_data_file", "content_offset", "content_size_in_bytes", "cardinality", "file_size"};
+	return std::move(result);
+}
+
+static unique_ptr<GlobalTableFunctionState> WriteDvsInit(ClientContext &context, TableFunctionInitInput &input) {
+	return make_uniq<WriteDvsGlobalState>();
+}
+
+static void WriteDvsFunction(ClientContext &context, TableFunctionInput &input, DataChunk &output) {
+	auto &bind_data = input.bind_data->Cast<WriteDvsBindData>();
+	auto &state = input.global_state->Cast<WriteDvsGlobalState>();
+	if (state.emitted) {
+		output.SetCardinality(0);
+		return;
+	}
+	output.SetCardinality(1);
+	output.SetValue(0, 0, Value(bind_data.referenced_data_file));
+	output.SetValue(1, 0, Value::BIGINT(bind_data.content_offset));
+	output.SetValue(2, 0, Value::BIGINT(bind_data.content_size_in_bytes));
+	output.SetValue(3, 0, Value::BIGINT(bind_data.cardinality));
+	output.SetValue(4, 0, Value::BIGINT(bind_data.file_size));
+	state.emitted = true;
+}
+
+} // namespace
+
+TableFunctionSet IcebergPuffinDvFunctions::GetWriteDvsFunction() {
+	TableFunctionSet set("iceberg_write_dvs");
+	set.AddFunction(TableFunction({LogicalType::VARCHAR, LogicalType::VARCHAR, LogicalType::LIST(LogicalType::BIGINT)},
+	                              WriteDvsFunction, WriteDvsBind, WriteDvsInit));
+	return set;
+}
+
+} // namespace duckdb
