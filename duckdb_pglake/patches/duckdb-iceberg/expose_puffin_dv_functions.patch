+//===--------------------------------------------------------------------===//
+// TVF: iceberg_puffin_read_blob(path, offset, length) -> (blob)
+//===--------------------------------------------------------------------===//
+
+namespace {
+
+struct PuffinReadBlobBindData : public TableFunctionData {
+	vector<data_t> payload;
+};
+
+struct PuffinReadBlobGlobalState : public GlobalTableFunctionState {
+	bool emitted = false;
+};
+
+static unique_ptr<FunctionData> PuffinReadBlobBind(ClientContext &context, TableFunctionBindInput &input,
+                                                   vector<LogicalType> &return_types, vector<string> &names) {
+	auto result = make_uniq<PuffinReadBlobBindData>();
+	auto path = input.inputs[0].GetValue<string>();
+	auto offset = input.inputs[1].GetValue<int64_t>();
+	auto length = input.inputs[2].GetValue<int64_t>();
+	auto &fs = FileSystem::GetFileSystem(context);
+	result->payload = IcebergPuffinFile::ReadBlobPayload(fs, path, offset, length);
+
+	return_types = {LogicalType::BLOB};
+	names = {"blob"};
+	return std::move(result);
+}
+
+static unique_ptr<GlobalTableFunctionState> PuffinReadBlobInit(ClientContext &context,
+                                                              TableFunctionInitInput &input) {
+	return make_uniq<PuffinReadBlobGlobalState>();
+}
+
+static void PuffinReadBlobFunction(ClientContext &context, TableFunctionInput &input, DataChunk &output) {
+	auto &bind_data = input.bind_data->Cast<PuffinReadBlobBindData>();
+	auto &state = input.global_state->Cast<PuffinReadBlobGlobalState>();
+	if (state.emitted) {
+		output.SetCardinality(0);
+		return;
+	}
+	output.SetCardinality(1);
+	output.SetValue(0, 0, Value::BLOB(bind_data.payload.data(), bind_data.payload.size()));
+	state.emitted = true;
+}
+
+} // namespace
+
+TableFunctionSet IcebergPuffinDvFunctions::GetReadBlobFunction() {
+	TableFunctionSet set("iceberg_puffin_read_blob");
+	set.AddFunction(TableFunction({LogicalType::VARCHAR, LogicalType::BIGINT, LogicalType::BIGINT},
+	                              PuffinReadBlobFunction, PuffinReadBlobBind, PuffinReadBlobInit));
+	return set;
+}
