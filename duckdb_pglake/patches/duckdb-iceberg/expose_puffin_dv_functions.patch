@@ -0,0 +1,61 @@
+//===----------------------------------------------------------------------===//
+//                         duckdb-iceberg
+//
+// iceberg_puffin_dv_functions.hpp
+//
+// Public DuckDB SQL surface for Puffin file + Iceberg V3 Deletion Vector
+// primitives. Registered by IcebergFunctions::GetTableFunctions / ::GetScalarFunctions.
+//
+//   Scalar functions:
+//     - iceberg_dv_encode(positions BIGINT[]) -> BLOB
+//
+//   Table functions:
+//     - iceberg_puffin_read_metadata(path VARCHAR) -> per-blob row
+//     - iceberg_puffin_read_blob(path VARCHAR, offset BIGINT, length BIGINT) -> BLOB
+//     - iceberg_puffin_write(path VARCHAR, blob_types VARCHAR[], blob_payloads BLOB[]) -> per-blob row
+//     - iceberg_dv_decode(blob BLOB) -> pos BIGINT
+//     - iceberg_dv_positions(paths VARCHAR[], offsets BIGINT[], sizes BIGINT[],
+//                            referenced_data_files VARCHAR[]) -> (file_path, pos)
+//       (one TVF call covers a whole scan: parallel arrays, no UNION ALL,
+//        result has the same shape as `read_parquet(<positional-delete-files>)`).
+//     - iceberg_write_dvs(path VARCHAR, referenced_data_file VARCHAR, positions BIGINT[]) ->
+//                  (referenced_data_file, content_offset, content_size_in_bytes, cardinality, file_size)
+//
+// See patches/duckdb-iceberg/README.md in the pg_lake repo for rationale.
+//
+//===----------------------------------------------------------------------===//
+
+#pragma once
+
+#include "duckdb/function/scalar_function.hpp"
+#include "duckdb/function/table_function.hpp"
+
+namespace duckdb {
+
+class IcebergPuffinDvFunctions {
+public:
+	//! BLOB iceberg_dv_encode(BIGINT[] positions)
+	static ScalarFunctionSet GetEncodeFunction();
+
+	//! TABLE iceberg_puffin_read_metadata(VARCHAR path)
+	static TableFunctionSet GetReadMetadataFunction();
+
+	//! TABLE iceberg_puffin_read_blob(VARCHAR path, BIGINT offset, BIGINT length)
+	static TableFunctionSet GetReadBlobFunction();
+
+	//! TABLE iceberg_puffin_write(VARCHAR path, VARCHAR[] blob_types, BLOB[] blob_payloads)
+	static TableFunctionSet GetWriteFunction();
+
+	//! TABLE iceberg_dv_decode(BLOB blob)
+	static TableFunctionSet GetDecodeFunction();
+
+	//! TABLE iceberg_dv_positions(VARCHAR[] paths, BIGINT[] offsets, BIGINT[] sizes,
+	//!                            VARCHAR[] referenced_data_files)
+	//!     -> TABLE(file_path VARCHAR, pos BIGINT)
+	static TableFunctionSet GetDvPositionsFunction();
+
+	//! TABLE iceberg_write_dvs(VARCHAR path, VARCHAR referenced_data_file, BIGINT[] positions)
+	static TableFunctionSet GetWriteDvsFunction();
+};
+
+} // namespace duckdb
