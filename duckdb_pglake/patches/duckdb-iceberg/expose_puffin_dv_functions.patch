+//===--------------------------------------------------------------------===//
+// TVF: iceberg_puffin_read_metadata(path) -> per-blob row
+//===--------------------------------------------------------------------===//
+
+namespace {
+
+struct PuffinMetadataBindData : public TableFunctionData {
+	IcebergPuffinMetadata metadata;
+};
+
+struct PuffinMetadataGlobalState : public GlobalTableFunctionState {
+	idx_t emit_offset = 0;
+};
+
+static unique_ptr<FunctionData> PuffinReadMetadataBind(ClientContext &context, TableFunctionBindInput &input,
+                                                      vector<LogicalType> &return_types, vector<string> &names) {
+	auto result = make_uniq<PuffinMetadataBindData>();
+	auto path = input.inputs[0].GetValue<string>();
+	auto &fs = FileSystem::GetFileSystem(context);
+	result->metadata = IcebergPuffinFile::ReadMetadata(fs, path);
+
+	return_types = {LogicalType::INTEGER,
+	                LogicalType::VARCHAR,
+	                LogicalType::LIST(LogicalType::INTEGER),
+	                LogicalType::BIGINT,
+	                LogicalType::BIGINT,
+	                LogicalType::BIGINT,
+	                LogicalType::BIGINT,
+	                LogicalType::VARCHAR,
+	                LogicalType::MAP(LogicalType::VARCHAR, LogicalType::VARCHAR),
+	                LogicalType::BIGINT,
+	                LogicalType::BOOLEAN};
+	names = {"blob_idx", "blob_type",         "fields",     "snapshot_id", "sequence_number",  "blob_offset",
+	         "blob_length", "compression_codec", "properties", "file_size",   "footer_compressed"};
+	return std::move(result);
+}
+
+static unique_ptr<GlobalTableFunctionState> PuffinReadMetadataInit(ClientContext &context,
+                                                                  TableFunctionInitInput &input) {
+	return make_uniq<PuffinMetadataGlobalState>();
+}
+
+static Value FieldsAsValue(const vector<int32_t> &fields) {
+	vector<Value> vals;
+	vals.reserve(fields.size());
+	for (auto f : fields) {
+		vals.push_back(Value::INTEGER(f));
+	}
+	return Value::LIST(LogicalType::INTEGER, std::move(vals));
+}
+
+static Value PropertiesAsMapValue(const map<string, string> &props) {
+	vector<Value> keys;
+	vector<Value> values;
+	for (auto &kv : props) {
+		keys.push_back(Value(kv.first));
+		values.push_back(Value(kv.second));
+	}
+	return Value::MAP(LogicalType::VARCHAR, LogicalType::VARCHAR, std::move(keys), std::move(values));
+}
+
+static void PuffinReadMetadataFunction(ClientContext &context, TableFunctionInput &input, DataChunk &output) {
+	auto &bind_data = input.bind_data->Cast<PuffinMetadataBindData>();
+	auto &state = input.global_state->Cast<PuffinMetadataGlobalState>();
+	auto &md = bind_data.metadata;
+	idx_t remaining = md.blobs.size() - state.emit_offset;
+	idx_t emit = MinValue<idx_t>(remaining, STANDARD_VECTOR_SIZE);
+	output.SetCardinality(emit);
+	for (idx_t i = 0; i < emit; i++) {
+		auto idx = state.emit_offset + i;
+		auto &b = md.blobs[idx];
+		output.SetValue(0, i, Value::INTEGER(static_cast<int32_t>(idx)));
+		output.SetValue(1, i, Value(b.type));
+		output.SetValue(2, i, FieldsAsValue(b.fields));
+		output.SetValue(3, i, b.snapshot_id >= 0 ? Value::BIGINT(b.snapshot_id) : Value(LogicalType::BIGINT));
+		output.SetValue(4, i,
+		                b.sequence_number >= 0 ? Value::BIGINT(b.sequence_number) : Value(LogicalType::BIGINT));
+		output.SetValue(5, i, Value::BIGINT(b.offset));
+		output.SetValue(6, i, Value::BIGINT(b.length));
+		output.SetValue(7, i, b.compression_codec.empty() ? Value(LogicalType::VARCHAR) : Value(b.compression_codec));
+		output.SetValue(8, i, PropertiesAsMapValue(b.properties));
+		output.SetValue(9, i, Value::BIGINT(md.file_size));
+		output.SetValue(10, i, Value::BOOLEAN(md.footer_compressed));
+	}
+	state.emit_offset += emit;
+}
+
+} // namespace
+
+TableFunctionSet IcebergPuffinDvFunctions::GetReadMetadataFunction() {
+	TableFunctionSet set("iceberg_puffin_read_metadata");
+	set.AddFunction(TableFunction({LogicalType::VARCHAR}, PuffinReadMetadataFunction, PuffinReadMetadataBind,
+	                              PuffinReadMetadataInit));
+	return set;
+}
