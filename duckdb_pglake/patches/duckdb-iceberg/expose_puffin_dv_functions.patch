diff --git a/src/function/iceberg_puffin_dv_functions.cpp b/src/function/iceberg_puffin_dv_functions.cpp
new file mode 100644
index 00000000..debdfa19
--- /dev/null
+++ b/src/function/iceberg_puffin_dv_functions.cpp
@@ -0,0 +1,652 @@
+//===----------------------------------------------------------------------===//
+//                         duckdb-iceberg
+//
+// iceberg_puffin_dv_functions.cpp
+//
+// Public SQL surface for Iceberg V3 Puffin envelope + Deletion Vector
+// primitives. The functions in this file are thin wrappers around
+//   - IcebergPuffinFile  (common/iceberg_puffin.{hpp,cpp}) and
+//   - IcebergDeletionVectorData::{ToBlob,ParseBlob} (core/deletes/...)
+// so the underlying behaviour is identical to duckdb-iceberg's internal
+// V3 read/write path. They exist to let projects that don't link
+// duckdb-iceberg as a C++ library (e.g. pg_lake's pgduck_server) consume
+// the codec via SQL.
+//
+//===----------------------------------------------------------------------===//
+
+#include "function/iceberg_puffin_dv_functions.hpp"
+
+#include "common/iceberg_puffin.hpp"
+#include "core/deletes/iceberg_deletion_vector.hpp"
+
+#include "duckdb/common/exception.hpp"
+#include "duckdb/common/file_system.hpp"
+#include "duckdb/common/string_util.hpp"
