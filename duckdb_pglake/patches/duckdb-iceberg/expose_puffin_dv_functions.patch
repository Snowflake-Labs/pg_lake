@@ -0,0 +1,104 @@
+//===----------------------------------------------------------------------===//
+//                         duckdb-iceberg
+//
+// iceberg_puffin.hpp
+//
+// Minimal, spec-compliant reader/writer for the Iceberg Puffin file format
+// (https://iceberg.apache.org/puffin-spec/). Supports:
+//
+//   * Magic-prefixed envelope (`PFA1` head + tail magic)
+//   * One or more arbitrary blobs concatenated between the magics
+//   * Footer JSON describing each blob's type, offset, length, optional
+//     fields[], snapshot-id, sequence-number, compression-codec, properties
+//   * Uncompressed footer payload on write (Flags=0)
+//   * Tolerant reader (raises a clear error on compressed footers since we
+//     do not yet decode LZ4_FRAME; otherwise reads any spec-conformant file)
+//
+// This is the foundation the public iceberg_puffin_* and iceberg_dv_*
+// table-valued and scalar functions sit on top of (see
+// `function/iceberg_puffin_dv_functions.hpp`).
+//
+//===----------------------------------------------------------------------===//
+
+#pragma once
+
+#include "duckdb/common/common.hpp"
+#include "duckdb/common/file_system.hpp"
+#include "duckdb/common/types.hpp"
+#include "duckdb/common/types/value.hpp"
+
+namespace duckdb {
+
+//! Iceberg Puffin file magic ("PFA1") - appears at offset 0, immediately
+//! before the footer payload, and as the very last 4 bytes of the file.
+extern const char ICEBERG_PUFFIN_MAGIC[4];
+
+//! Metadata for a single blob inside a Puffin file. Mirrors the JSON object
+//! shape described in the Iceberg Puffin spec under "Blob metadata".
+struct IcebergPuffinBlob {
+	string type;
+	//! Optional list of field-ids the blob applies to (Iceberg V3 manifest
+	//! field 142 for deletion vectors). May be empty.
+	vector<int32_t> fields;
+	//! Optional Iceberg snapshot id this blob was written under; -1 if absent.
+	int64_t snapshot_id = -1;
+	//! Optional sequence number; -1 if absent.
+	int64_t sequence_number = -1;
+	//! Byte offset of the blob payload inside the Puffin file. For files we
+	//! write this is always >= 4 (the head magic is at offset 0..3).
+	int64_t offset = 0;
+	//! Byte length of the blob payload.
+	int64_t length = 0;
+	//! Compression codec for the blob payload itself. Empty string means
+	//! uncompressed (the typical case for deletion-vector-v1 blobs).
+	string compression_codec;
+	//! Free-form per-blob properties.
+	map<string, string> properties;
+
+	//! Raw blob payload bytes. Only populated by the writer (input side) and
+	//! by reader call paths that explicitly request payload materialization.
+	vector<data_t> payload;
+};
+
+//! Convenience holder for the parsed file-level metadata (everything from the
+//! footer JSON, plus the absolute file size). `blobs[*].payload` is empty
+//! when produced by `IcebergPuffinFile::ReadMetadata` - call
+//! `IcebergPuffinFile::ReadBlobPayload` (or read raw bytes via DuckDB's
+//! filesystem) to materialize a single blob without re-parsing the footer.
+struct IcebergPuffinMetadata {
+	vector<IcebergPuffinBlob> blobs;
+	map<string, string> properties;
+	int64_t file_size = 0;
+	//! True if the file was written with a compressed footer payload.
+	//! `ReadMetadata` raises rather than returns true today, because we do
+	//! not yet decompress LZ4_FRAME footers; the field is preserved here for
+	//! future-proofing.
+	bool footer_compressed = false;
+};
+
+//! Public Puffin reader: open + parse footer JSON, then optionally read
+//! individual blob payloads. All I/O goes through DuckDB's FileSystem, so
+//! S3 / Azure / local paths are supported uniformly.
+class IcebergPuffinFile {
+public:
+	//! Read the Puffin envelope at `path` and return its parsed metadata
+	//! (file_size, blobs[], properties). Does NOT materialize blob bytes.
+	static IcebergPuffinMetadata ReadMetadata(FileSystem &fs, const string &path);
+
+	//! Read a single blob payload by absolute byte offset + length (these are
+	//! the values stored in the Iceberg manifest's content_offset and
+	//! content_size_in_bytes fields for V3 deletion-vector entries, or
+	//! `blob.offset` and `blob.length` from `ReadMetadata`).
+	static vector<data_t> ReadBlobPayload(FileSystem &fs, const string &path, int64_t offset, int64_t length);
+
+	//! Write `blobs` (in order) into a new Puffin file at `path`. Each
+	//! `IcebergPuffinBlob::payload` must contain the blob bytes to write;
+	//! `offset` and `length` are populated by the writer and returned in the
+	//! result. The footer is always written uncompressed (Flags=0). Returns
+	//! a metadata object whose blobs[] mirror the input with offset/length
+	//! filled in, plus the total `file_size`.
+	static IcebergPuffinMetadata Write(FileSystem &fs, const string &path, vector<IcebergPuffinBlob> blobs,
+	                                   const map<string, string> &file_properties = {});
+};
+
+} // namespace duckdb
